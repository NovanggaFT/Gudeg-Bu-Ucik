// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum StatusStok {
  aman
  waspada
  habis
  belum_terjadi
}

model DataPenjualan {
  id              String   @id @default(cuid())
  hppPerPorsi     Int      @default(13000)
  hargaJualPerPorsi Int    @default(15000)
  labaPerPorsi    Int      @default(2000)
  targetHarian    Int      @default(200)
  stokAwal        Int      @default(500)
  thresholdBelanja Int    @default(200)
  tanggalBerlaku  DateTime @default(now())
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  realisasi       RealisasiHarian[]
  riwayatBelanja  RiwayatBelanja[]

  @@index([tanggalBerlaku])
}

model RealisasiHarian {
  id          String   @id @default(cuid())
  tanggal     DateTime @default(now())
  terjual     Int      @default(0)
  sisa        Int      @default(0)
  stokAwal    Int      @default(0)
  status      StatusStok @default(belum_terjadi)
  perluBelanja Boolean @default(false)
  dataPenjualanId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  dataPenjualan DataPenjualan @relation(fields: [dataPenjualanId], references: [id], onDelete: Cascade)

  @@index([tanggal])
  @@index([dataPenjualanId])
  @@unique([tanggal, dataPenjualanId])  // 1 hari 1 record
}

model RiwayatBelanja {
  id          String   @id @default(cuid())
  tanggal     DateTime @default(now())
  
  // 👇 INPUT USER (MANUAL)
  jumlah      Int?      // Jumlah unit (opsional)
  total       Int?      // Total harga (opsional)
  
  // 👇 SYSTEM (AUTO CALCULATED)
  jumlahSystem Int?     // Dihitung dari total / hppPerPorsi
  totalSystem  Int?     // Dihitung dari jumlah x hppPerPorsi
  
  // 👇 MASTER DATA (SNAPSHOT saat transaksi)
  hppPerPorsi  Int      // Copy dari DataPenjualan.hppPerPorsi
  
  keterangan  String?
  dataPenjualanId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  dataPenjualan DataPenjualan @relation(fields: [dataPenjualanId], references: [id], onDelete: Cascade)

  @@index([tanggal])
  @@index([dataPenjualanId])
}